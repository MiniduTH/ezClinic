# ─── Database (Supabase) ──────────────────────────────────────────────────────
SUPABASE_DB_URL=jdbc:postgresql://<host>:5432/postgres
SUPABASE_DB_USER=postgres
SUPABASE_DB_PASSWORD=<supabase db password>

# patient-admin-service uses this form:
DATABASE_URL=postgresql://postgres:<password>@<host>:5432/postgres

# ─── MongoDB (doctor-service) ─────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/doctor_db?retryWrites=true

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ─── PayHere ─────────────────────────────────────────────────────────────────
