# ─── Databases (one Supabase project per service) ────────────────────────────

# patient-admin-service  →  NestJS TypeORM  (postgresql:// connection string)
PATIENT_DB_URL=postgresql://postgres:<password>@<host>:5432/<db>

# appointment-booking-service  →  Spring Boot JPA  (jdbc:postgresql:// + separate user/pass)
APPOINTMENT_DB_URL=jdbc:postgresql://<host>:5432/<db>
APPOINTMENT_DB_USER=postgres
APPOINTMENT_DB_PASSWORD=<password>

# telemedicine-notification-service  →  Spring Boot JPA
# Note: DB host URL is hardcoded in application.yaml — only user/pass are needed here
TELEMEDICINE_DB_USER=postgres
TELEMEDICINE_DB_PASSWORD=<password>

# ─── MongoDB (doctor-service) ─────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/doctor_db?retryWrites=true

# ─── RabbitMQ ─────────────────────────────────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ─── PayHere ─────────────────────────────────────────────────────────────────
PAYHERE_MERCHANT_ID=<your merchant id>
PAYHERE_MERCHANT_SECRET=<your merchant secret>
# For local dev use ngrok or similar to expose port 8000 publicly for the webhook
PAYHERE_NOTIFY_URL=https://<ngrok-or-public-url>/api/payments/payhere/notify
PAYHERE_RETURN_URL=http://localhost:3000/appointments?status=success
PAYHERE_CANCEL_URL=http://localhost:3000/appointments?status=cancelled

# ─── Mailtrap ─────────────────────────────────────────────────────────────────
MAILTRAP_API_KEY=<your mailtrap api key>
MAILTRAP_SENDER=noreply@ezclinic.com

# ─── Jitsi ───────────────────────────────────────────────────────────────────
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=<your jitsi app id>
JITSI_APP_SECRET=<your jitsi app secret>

# ─── Google Gemini AI ─────────────────────────────────────────────────────────
GEMINI_API_KEY=<your gemini api key>
GEMINI_MODEL=gemini-2.5-flash

# ─── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000

# ─── Kong API Gateway ─────────────────────────────────────────────────────────
# Public URL that browsers use to reach Kong.
# Baked into the Next.js JS bundle at build time — change requires a rebuild.
# Local dev default: http://localhost:8000
# Staging / prod example: https://api.ezclinic.com
KONG_URL=http://localhost:8000
