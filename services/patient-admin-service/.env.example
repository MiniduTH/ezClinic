# Application
PORT=3005
NODE_ENV=development

# JWT Secret (shared with doctor-service and frontend)
JWT_SECRET=YOUR_JWT_SECRET

# RabbitMQ
RABBITMQ_URL=YOUR_RABBITMQ_URL

# Database (Supabase PostgreSQL)
DATABASE_URL=YOUR_DATABASE_URL

# Local File Storage
# Path (relative to project root) where uploaded medical reports are saved
UPLOAD_DIR=uploads/medical-reports
# Base URL of this service, used to build public file links
APP_BASE_URL=http://localhost:3005

# Initial admin credentials (used to seed the first admin account on startup)
# Default email is admin@example.com; override password below for production
INITIAL_ADMIN_PASSWORD=Pass@123
