# Application
PORT=3001
NODE_ENV=development

# Auth0
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.ezclinic.com

# JWT (for internal service-to-service calls)
JWT_SECRET=your_super_secret_jwt_key

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672

# File Storage (Supabase Storage)
DATABASE_URL=postgresql://postgres:[pwd]@db.host.supabase.co:5432/user

#R2
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_ENDPOINT=
R2_BUCKET_NAME=

# Local File Storage
# Path (relative to project root) where uploaded medical reports are saved
UPLOAD_DIR=uploads/medical-reports
# Base URL of this service, used to build public file links
APP_BASE_URL=http://localhost:3005
