# Application
PORT=3005
NODE_ENV=development

# Auth0
AUTH0_DOMAIN=YOUR_AUTH0_DOMAIN
AUTH0_AUDIENCE=YOUR_AUTH0_AUDIENCE

# JWT (for internal service-to-service calls)
JWT_SECRET=YOUR_JWT_SECRET

# RabbitMQ
RABBITMQ_URL=YOUR_RABBITMQ_URL

# Database (Supabase PostgreSQL)
DATABASE_URL=YOUR_DATABASE_URL

# Local File Storage
# Path (relative to project root) where uploaded medical reports are saved
UPLOAD_DIR=uploads/medical-reports
# Base URL of this service, used to build public file links
APP_BASE_URL=http://localhost:3005
