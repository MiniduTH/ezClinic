# ─── Server ─────────────────────────────────────────────────────────────────
PORT=8080

# ─── Database (Supabase PostgreSQL) ─────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=your_supabase_db_password
DDL_AUTO=update

# ─── Auth0 ──────────────────────────────────────────────────────────────────
AUTH0_DOMAIN=your-tenant.auth0.com
AUTH0_AUDIENCE=https://api.ezclinic.com

# ─── RabbitMQ ────────────────────────────────────────────────────────────────
# Point this to the team leader's machine IP on the shared network
RABBITMQ_HOST=<team-leader-ip>
RABBITMQ_PORT=5672
RABBITMQ_USER=guest
RABBITMQ_PASS=guest

# ─── Email (Mailtrap) ────────────────────────────────────────────────────────
MAILTRAP_API_KEY=your_mailtrap_api_key
SENDER=your_verified_sender_email

# ─── Jitsi Meet ──────────────────────────────────────────────────────────────
JITSI_DOMAIN=meet.jit.si
JITSI_APP_ID=
JITSI_APP_SECRET=

# ─── Google Gemini AI ────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key
GEMINI_MODEL=gemini-2.0-flash

# ─── Inter-service URLs ──────────────────────────────────────────────────────
APPOINTMENT_SERVICE_URL=http://localhost:3004/api/v1

# ─── CORS ────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
